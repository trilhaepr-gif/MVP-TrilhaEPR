<!DOCTYPE html>
<html lang="pt-BR">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Trilha EPR - Simulador de Fluxograma</title>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/PapaParse/5.3.2/papaparse.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/html2canvas/1.4.1/html2canvas.min.js"></script>

    <!-- ========================================== -->
    <!-- ZONA 1: ESTILOS E ANIMAÇÕES (CSS)        -->
    <!-- ========================================== -->
    <link rel="stylesheet" href="style.css">
</head>

<body>

    <!-- ========================================== -->
    <!-- ZONA 2: HEADER E CONTROLES DE SIMULAÇÃO    -->
    <!-- ========================================== -->
    <header>
        <div class="header-top">
            <div class="header-esq">
                <div style="display: flex; align-items: center; gap: 10px;">
                    <h1>Trilha EPR <span
                            style="font-size:0.7rem; color:#4facfe; font-weight:normal; letter-spacing:1px;">|
                            Simulador de Fluxo</span></h1>
                    <div class="wrapper-ajuda">
                        <button class="btn-ajuda-circulo">?</button>
                        <div class="guia-popover">
                            <div class="guia-titulo">✨ Guia de Uso Rápido</div>
                            <ul class="guia-lista">
                                <li><span>1</span> Navegue pelas Obrigatórias e Optativas.</li>
                                <li><span>2</span> Clique nas disciplinas que já cursou para verificar sua percentagem
                                    de evolução no curso.</li>
                                <li><span>3</span> Preste atenção às cores (Pré-requisitos bloqueados, etc).</li>
                                <li><span>4</span> Use o ✨Simular com IA para otimizar horários, evitar choques e
                                    descobrir as disciplinas perfeitas para o seu perfil.</li>
                            </ul>
                        </div>
                    </div>
                </div>
                <div class="termometro-wrapper">
                    <div id="termometro" class="termometro status-verde">Saudável</div>
                    <div id="msg-termometro" class="msg-termometro">Comece a marcar suas matérias.</div>
                </div>
            </div>
            <div class="header-dir">
                <div class="grupo-controles">
                    <div class="nivel-badge" id="txt-nivel">Menor Pendência: 1º Período</div>
                    <div class="contador-semestres">
                        <span style="color: #aaa; font-weight: normal; font-size: 0.7rem;">Tempo:</span>
                        <button onclick="mudarSemestre(-1)">-</button>
                        <span id="txt-semestres">1 semestre</span>
                        <button onclick="mudarSemestre(1)">+</button>
                    </div>
                    <div class="botoes-acao">
                        <button class="btn-simular" id="btn-modo-sim" onclick="toggleModoSimulacao()">✨ Simular com
                            IA</button>
                        <button class="btn-reset" onclick="limparProgresso()">Zerar</button>
                    </div>
                </div>
                <div class="perc-display" id="perc-container"><span id="txt-perc">0.0</span><span
                        class="perc-symbol">%</span></div>
            </div>
        </div>

        <div class="header-search-bar">
            <input type="text" id="campo-busca" placeholder="🔎 Pesquisar por nome ou código..." autocomplete="off">
        </div>
    </header>

    <!-- ══════════════════════════════════════════════════════════════════ -->
    <!-- BOTÃO FLUTUANTE: Abre o Dashboard Analítico                       -->
    <!-- ══════════════════════════════════════════════════════════════════ -->
    <button id="btn-abrir-dashboard" onclick="abrirDashboardOverlay()" title="Ver Análise do Perfil">
        <span class="dash-btn-icon">&#128202;</span>
        Ver Análise do Perfil
    </button>

    <!-- ══════════════════════════════════════════════════════════════════ -->
    <!-- ZONA: DASHBOARD ANALÍTICO FULL-SCREEN (OVERLAY/SPA)              -->
    <!-- ══════════════════════════════════════════════════════════════════ -->
    <div id="dashboard-overlay" role="dialog" aria-modal="true" aria-label="Dashboard Analítico">
        <div class="dash-panel">
            <div class="dash-header">
                <div class="dash-titulo-box">
                    <h2 style="margin:0; font-size: 1.2rem; color: #fff;">Análise do Perfil Acadêmico</h2>
                </div>
                <button class="dash-btn-fechar" onclick="fecharDashboardOverlay()"
                    title="Minimizar dashboard">&minus;</button>
            </div>
            <div class="dash-body">
                <nav class="dash-sidebar">
                    <span class="dash-sidebar-label">Navegação</span>
                    <a class="dash-nav-item ativo" href="#dash-resumo" onclick="dashNavAtivar(this)">
                        <span class="dash-nav-icon">&#127968;</span> Resumo
                    </a>
                    <a class="dash-nav-item" href="#dash-graficos" onclick="dashNavAtivar(this)">
                        <span class="dash-nav-icon">&#128200;</span> Gráficos
                    </a>
                    <a class="dash-nav-item" href="#dash-disciplinas" onclick="dashNavAtivar(this)">
                        <span class="dash-nav-icon">&#128203;</span> Disciplinas
                    </a>
                    <span class="dash-sidebar-label" style="margin-top:auto;">Filtros Tabela</span>
                    <a class="dash-nav-item" href="#" onclick="dashFiltrarTabela('todas');return false;">
                        <span class="dash-nav-icon">&#9889;</span> Todas
                    </a>
                    <a class="dash-nav-item" href="#" onclick="dashFiltrarTabela('OBG');return false;">
                        <span class="dash-nav-icon">&#127891;</span> Obrigatórias
                    </a>
                    <a class="dash-nav-item" href="#" onclick="dashFiltrarTabela('OPT');return false;">
                        <span class="dash-nav-icon">&#128204;</span> Optativas
                    </a>
                </nav>
                <div class="dash-content" id="dash-content-area">

                    <!-- SEÇÃO RESUMO -->
                    <section id="dash-resumo" class="dash-secao">
                        <div class="dash-secao-titulo">&#128202; Indicadores de Progresso</div>
                        <div class="dash-kpi-grid">
                            <div class="dash-kpi-card" style="--kpi-cor: linear-gradient(90deg,#4facfe,#00f2fe);">
                                <div class="dash-kpi-label">Total Integralizado</div>
                                <div class="dash-kpi-valor"><span id="dk-horas-total">0</span><span> / 3600h</span>
                                </div>
                                <div class="dash-kpi-sub" id="dk-horas-sub">Clique em disciplinas para começar</div>
                                <div class="dash-kpi-barra-outer">
                                    <div class="dash-kpi-barra-inner" id="dk-barra-total" style="width:0%"></div>
                                </div>
                            </div>
                            <div class="dash-kpi-card" style="--kpi-cor: linear-gradient(90deg,#43e97b,#38f9d7);">
                                <div class="dash-kpi-label">Conclusão do Curso</div>
                                <div class="dash-kpi-valor"><span id="dk-perc">0.0</span><span> %</span></div>
                                <div class="dash-kpi-sub">da carga total exigida (3600h)</div>
                                <div class="dash-kpi-barra-outer">
                                    <div class="dash-kpi-barra-inner" id="dk-barra-perc"
                                        style="width:0%; background:linear-gradient(90deg,#43e97b,#38f9d7)"></div>
                                </div>
                            </div>
                            <div class="dash-kpi-card" style="--kpi-cor: linear-gradient(90deg,#e91e63,#f06292);">
                                <div class="dash-kpi-label">Obrigatórias (OBG)</div>
                                <div class="dash-kpi-valor"><span id="dash-obg-text">0</span><span> / 2265h</span></div>
                                <div class="dash-kpi-sub">horas de obrigatórias registradas</div>
                                <div class="dash-kpi-barra-outer">
                                    <div class="dash-kpi-barra-inner" id="dk-barra-obg"
                                        style="width:0%; background:linear-gradient(90deg,#e91e63,#f06292)"></div>
                                </div>
                            </div>
                            <div class="dash-kpi-card" style="--kpi-cor: linear-gradient(90deg,#f9a825,#ffb74d);">
                                <div class="dash-kpi-label">Optativas Completadas</div>
                                <div class="dash-kpi-valor"><span id="dk-horas-opt">0</span><span> / 1335h</span></div>
                                <div class="dash-kpi-sub">horas de optativas registradas</div>
                                <div class="dash-kpi-barra-outer">
                                    <div class="dash-kpi-barra-inner" id="dk-barra-opt"
                                        style="width:0%; background:linear-gradient(90deg,#f9a825,#ffb74d)"></div>
                                </div>
                            </div>
                            <div class="dash-kpi-card" style="--kpi-cor: linear-gradient(90deg,#fa709a,#fee140);">
                                <div class="dash-kpi-label">Trilha Predominante</div>
                                <div class="dash-kpi-valor" style="font-size:1.05rem; margin-top:4px;" id="dk-trilha">—
                                </div>
                                <div class="dash-kpi-sub" id="dk-trilha-sub">Área com mais horas especializadas</div>
                                <div class="dash-kpi-barra-outer">
                                    <div class="dash-kpi-barra-inner" id="dk-barra-trilha"
                                        style="width:0%; background:linear-gradient(90deg,#fa709a,#fee140)"></div>
                                </div>
                            </div>
                            <div class="dash-kpi-card" style="--kpi-cor: linear-gradient(90deg,#a18cd1,#fbc2eb);">
                                <div class="dash-kpi-label">Módulo Livre</div>
                                <div class="dash-kpi-valor"><span id="dk-ml">0</span><span> / 360h</span></div>
                                <div class="dash-kpi-sub">horas complementares</div>
                                <div class="dash-kpi-barra-outer">
                                    <div class="dash-kpi-barra-inner" id="dk-barra-ml"
                                        style="width:0%; background:linear-gradient(90deg,#a18cd1,#fbc2eb)"></div>
                                </div>
                            </div>
                        </div>
                    </section>

                    <!-- SEÇÃO GRÁFICOS -->
                    <section id="dash-graficos" class="dash-secao">
                        <div class="dash-secao-titulo">&#128200; Distribuição por Área</div>
                        <div class="dash-graficos-grid">
                            <div class="dash-grafico-card">
                                <div class="dash-grafico-titulo"><span>&#128376;</span> Radar de Competências</div>
                                <div class="dash-canvas-wrapper"><canvas id="dash-chart-radar"></canvas></div>
                            </div>
                            <div class="dash-grafico-card">
                                <div class="dash-grafico-titulo"><span>&#127849;</span> Composição da Carga</div>
                                <div class="dash-canvas-wrapper"><canvas id="dash-chart-doughnut"></canvas></div>
                            </div>
                        </div>
                    </section>

                    <!-- SEÇÃO TABELA -->
                    <section id="dash-disciplinas" class="dash-secao">
                        <div class="dash-secao-titulo">&#128203; Disciplinas Concluídas</div>
                        <div class="dash-tabela-container" style="max-height: 400px; overflow-y: auto;">
                            <table class="dash-tabela">
                                <thead>
                                    <tr>
                                        <th>Código</th>
                                        <th>Nome</th>
                                        <th>Área</th>
                                        <th>Tipo</th>
                                        <th style="text-align:right;">Horas</th>
                                    </tr>
                                </thead>
                                <tbody id="dash-tabela-body">
                                    <tr>
                                        <td colspan="5"
                                            style="text-align:center; color:#475569; padding:30px; font-style:italic;">
                                            Nenhuma disciplina concluída ainda.</td>
                                    </tr>
                                </tbody>
                            </table>
                        </div>
                        <div class="dash-paginacao">
                            <button class="dash-pag-btn" id="dash-pag-ant" onclick="dashMudarPagina(-1)"
                                disabled>&#8249; Anterior</button>
                            <span class="dash-pag-info" id="dash-pag-info">Pág 1 / 1</span>
                            <button class="dash-pag-btn" id="dash-pag-prox" onclick="dashMudarPagina(1)"
                                disabled>Próximo &#8250;</button>
                        </div>
                    </section>

                    <!-- PAINEL DE TELEMETRIA (DEBUG MODE) - Oculto para produção -->
                    <div id="debug-telemetria"
                        style="display: none; margin-top: 20px; padding: 12px; background: #000; color: #0f0; font-family: 'Courier New', monospace; font-size: 0.75rem; border-radius: 6px; border: 1px solid #333; white-space: pre-line;">
                        === MODO DEBUG / TELEMETRIA ===
                        [Lido dos Inputs] Piso OBG: 0 | Piso OPT: 0
                        [Lido dos Cards] Cliques OBG: 0 | Cliques OPT: 0 | Cliques ML: 0
                        [Cálculo Math.max] Total OBG: 0 | Total OPT+ML: 0
                        [Cálculo Final (Tetos)] OBG Final: 0 | OPT Final: 0
                        [Total] Horas Validadas: 0 | Percentagem: 0.0%
                    </div>

                </div><!-- /dash-content -->
            </div><!-- /dash-body -->
        </div><!-- /dash-panel -->
    </div><!-- /dashboard-overlay -->


    <div id="barra-simulacao" class="barra-simulacao">
        <div class="sim-info" style="flex: 1; min-width: 0; overflow: hidden;">
            <div style="font-weight:bold;">📅 Simulação de Matrícula</div>
            <div style="font-size:0.85rem;">Total selecionado: <b id="sim-horas">0</b>h.</div>
            <div id="lista-liberadas"
                style="font-size: 0.8rem; color: #00e676; margin-top: 5px; font-weight: bold; width: 100%; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;">
                Liberadas: Nenhuma</div>
        </div>

        <div class="ia-controls" style="flex: 2; align-items: center; justify-content: center; width: 100%;">
            <div id="ia-bloco-selecao" class="ia-modo-selecao">
                <div style="width: 100%; text-align: center; margin-bottom: 4px; font-size: 0.8rem; color: #aaa;">
                    1. Escolha o seu foco profissional:
                </div>
                <div class="ia-cards-container">
                    <div class="card-trilha" onclick="selecionarCardTrilha('Eng. de Operações', this)">
                        <div class="card-trilha-icon">⚙️</div>
                        <div class="card-trilha-titulo">Operações</div>
                        <div class="card-trilha-desc">Produção e PCP.</div>
                    </div>
                    <div class="card-trilha" onclick="selecionarCardTrilha('Logística', this)">
                        <div class="card-trilha-icon">📦</div>
                        <div class="card-trilha-titulo">Logística</div>
                        <div class="card-trilha-desc">Supply e Transportes.</div>
                    </div>
                    <div class="card-trilha" onclick="selecionarCardTrilha('Pesquisa Operacional/Dados', this)">
                        <div class="card-trilha-icon">📊</div>
                        <div class="card-trilha-titulo">Dados & PO</div>
                        <div class="card-trilha-desc">Otimização e IA.</div>
                    </div>
                    <div class="card-trilha" onclick="selecionarCardTrilha('Gestão e Economia', this)">
                        <div class="card-trilha-icon">💼</div>
                        <div class="card-trilha-titulo">Gestão & Econ.</div>
                        <div class="card-trilha-desc">Finanças e Projetos.</div>
                    </div>
                    <div class="card-trilha" onclick="selecionarCardTrilha('Explorar', this)">
                        <div class="card-trilha-icon">🎲</div>
                        <div class="card-trilha-titulo">Surpreenda-me</div>
                        <div class="card-trilha-desc">Equilíbrio da grade.</div>
                    </div>
                </div>
                <div style="width: 100%; text-align: center; margin-bottom: 2px;">
                    <button id="btn-executar-ia" class="btn-ia" disabled onclick="executarIA()"
                        style="padding: 6px 25px; font-size: 0.85rem; opacity: 0.5;">
                        ✨ Auto-Completar
                    </button>
                </div>
                <!-- Controls like burden slider kept here so it hides safely too if we want, or keep it out? User asked to have the ia-controls encompass the ia-bloco-compacto, we'll maintain slider structure out of blocks so it's always visible! -->
            </div>

            <div id="ia-bloco-compacto" class="ia-modo-compacto">
                <span style="color: #4facfe; font-size: 0.85rem;">✨ Trilha Ativa: <b
                        id="txt-trilha-ativa">Nenhuma</b></span>
                <button class="btn-alterar-trilha" onclick="reabrirSelecaoTrilha()">🔄 Alterar Trilha</button>
            </div>

            <div
                style="display: flex; flex-direction: column; align-items: center; justify-content: center; margin-top: 5px;">
                <label for="ia-carga" style="font-size: 0.7rem; color: #aaa; margin-bottom: 2px;">
                    Carga IA: <b id="valor-carga" style="color: #fff;">240h</b>
                </label>
                <input type="range" id="ia-carga" min="120" max="420" step="30" value="240"
                    style="width: 120px; cursor: pointer; height: 12px;"
                    oninput="document.getElementById('valor-carga').innerText = this.value + 'h'">
            </div>
        </div>

        <div style="display: flex; gap: 10px; align-items: center; flex: 1; justify-content: flex-end;">
            <button id="btn-grade-visual" class="btn-limpar-sim" onclick="abrirModalGrade()"
                style="border-color: #4facfe; color: #4facfe;">📅 Ver Grade</button>
            <button class="btn-limpar-sim" onclick="resetarSimulacaoAtual()"
                style="border-color: #f44336; color: #f44336;">🗑️ Limpar</button>
            <button class="btn-limpar-sim" onclick="limparSimulacao()">Sair</button>
        </div>
    </div>

    <!-- ========================================== -->
    <!-- ZONA 3: MODAL DA GRADE VISUAL              -->
    <!-- ========================================== -->
    <div id="modal-grade" class="modal-overlay">
        <div class="modal-ia">
            <div class="modal-header">
                <h3 style="color:#4facfe; margin:0;">📅 Grade Horária Simulada</h3>
                <div style="display: flex; gap: 15px; align-items: center;">
                    <button id="btn-baixar-grade" onclick="baixarGradePNG()"
                        style="background: transparent; color: #00e676; border: 1px solid #00e676; padding: 4px 12px; border-radius: 4px; font-size: 0.8rem; cursor: pointer; transition: 0.2s; font-weight: bold;">
                        📥 Salvar Imagem
                    </button>
                    <button class="btn-fechar-modal" onclick="fecharModalGrade()">&times;</button>
                </div>
            </div>
            <div class="modal-body" id="modal-grade-body" style="overflow-x: auto;"></div>
        </div>
    </div>

    <div class="main-container">
        <div class="boas-vindas">
            <h2 style="font-size: 1.2rem; margin-bottom: 5px;">Planeje sua trilha na EPR.</h2>
            <p style="font-size: 0.85rem; color: #ccc; max-width: 600px; margin: 0 auto; line-height: 1.4;">
                Clique nas matérias para marcá-las como <em>concluídas</em>. Ative a <strong>✨ Simulação por IA</strong>
                no cabeçalho para planear seu semestre sem choques de horário.
            </p>
        </div>

        <div class="secao-especial" style="border-color: #888;">
            <div class="secao-titulo">Banco de Cadeias Seletivas (Necessário cursar pelo menos 1 de cada cadeia)</div>
            <div id="seletivas-grid" class="grid-seletivas"></div>
        </div>

        <div id="fluxograma-container" class="fluxograma-container"></div>

        <div class="secao-especial">
            <div class="secao-titulo">Vitrine de Optativas (Filtrar e Planejar)</div>
            <div class="filtros-container">
                <button id="btn-todas" class="pilula-filtro ativa"
                    onclick="filtrarOptativas('todas', event)">Todas</button>
                <button id="btn-prodesp" class="pilula-filtro"
                    onclick="filtrarOptativas('prodesp', event)">Engenharias</button>
                <button id="btn-humanas" class="pilula-filtro" onclick="filtrarOptativas('humanas', event)">Humanas /
                    Gestão</button>
                <button id="btn-exatas" class="pilula-filtro" onclick="filtrarOptativas('exatas', event)">Exatas /
                    TI</button>
            </div>
            <div id="carrossel-optativas" class="carrossel-optativas"></div>

            <!-- ZONA: CARGA HORÁRIA COMPLEMENTAR (Módulo Livre) -->
            <div class="secao-complementar">
                <div class="secao-complementar-titulo">
                    <span>📚</span>
                    <span>Módulo Livre</span>
                    <span
                        style="font-size:0.65rem; font-weight:normal; color:#555; text-transform:none; letter-spacing:0;">
                        (até 360h aproveitáveis pelo SIGAA)
                    </span>
                    <span id="ml-total-display" class="ml-total-badge" style="display:none;">0h</span>
                </div>
                <div class="stepper-lista">
                    <!-- ML 30h -->
                    <div class="stepper-row">
                        <span class="stepper-label">Módulo Livre <strong>30h</strong></span>
                        <div class="stepper-controls">
                            <button class="stepper-btn" onclick="alterarML(30, -1)">-</button>
                            <span class="stepper-valor" id="count-ml-30">0</span>
                            <button class="stepper-btn" onclick="alterarML(30, 1)">+</button>
                        </div>
                        <span class="stepper-subtotal" id="sub-ml30"></span>
                    </div>
                    <!-- ML 45h -->
                    <div class="stepper-row">
                        <span class="stepper-label">Módulo Livre <strong>45h</strong></span>
                        <div class="stepper-controls">
                            <button class="stepper-btn" onclick="alterarML(45, -1)">-</button>
                            <span class="stepper-valor" id="count-ml-45">0</span>
                            <button class="stepper-btn" onclick="alterarML(45, 1)">+</button>
                        </div>
                        <span class="stepper-subtotal" id="sub-ml45"></span>
                    </div>
                    <!-- ML 60h -->
                    <div class="stepper-row">
                        <span class="stepper-label">Módulo Livre <strong>60h</strong></span>
                        <div class="stepper-controls">
                            <button class="stepper-btn" onclick="alterarML(60, -1)">-</button>
                            <span class="stepper-valor" id="count-ml-60">0</span>
                            <button class="stepper-btn" onclick="alterarML(60, 1)">+</button>
                        </div>
                        <span class="stepper-subtotal" id="sub-ml60"></span>
                    </div>
                    <!-- ML 90h -->
                    <div class="stepper-row">
                        <span class="stepper-label">Módulo Livre <strong>90h</strong></span>
                        <div class="stepper-controls">
                            <button class="stepper-btn" onclick="alterarML(90, -1)">-</button>
                            <span class="stepper-valor" id="count-ml-90">0</span>
                            <button class="stepper-btn" onclick="alterarML(90, 1)">+</button>
                        </div>
                        <span class="stepper-subtotal" id="sub-ml90"></span>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- ========================================== -->
    <!-- ZONA 4: JAVASCRIPT - ESTADO E API          -->
    <!-- ========================================== -->
    <script src="app.js" defer></script>
    <!-- Tooltip Global -->
    <div id="custom-tooltip"></div>
    
</body>

</html>